<!DOCTYPE html>
<html>
<head>
<title>Shopping Cart</title>

<style>

body{
font-family:Arial;
background:#f5f5f5;
margin:0;
}

header{
background:#0d6efd;
color:white;
padding:20px;
text-align:center;
}

table{
width:90%;
margin:20px auto;
border-collapse:collapse;
background:white;
}

th,td{
border:1px solid #ddd;
padding:12px;
text-align:center;
}

th{
background:#0d6efd;
color:white;
}

.btn{
padding:10px 18px;
border:none;
border-radius:5px;
cursor:pointer;
color:white;
text-decoration:none;
}

.remove{
background:red;
}

.checkout{
background:green;
}

.home{
background:#0d6efd;
}

.total{
text-align:center;
font-size:22px;
margin:20px;
font-weight:bold;
}

.buttons{
text-align:center;
margin:30px;
}

</style>

</head>

<body>

<header>

<h1>🛒 Master Sewing Machine House</h1>

</header>

<table>

<tr>

<th>Product</th>
<th>Price</th>
<th>Action</th>

</tr>

{% for item in cart_products %}

<tr>

<td>{{ item[1] }}</td>

<td>₹ {{ item[2] }}</td>

<td>

<a class="btn remove" href="/remove/{{ item[0] }}">
Remove
</a>

</td>

</tr>

{% endfor %}

</table>

<div class="total">

Total Products : {{ total_items }}

<br><br>

Total Bill : ₹ {{ total_bill }}

</div>

<div class="buttons">

<a class="btn checkout" href="/">
Checkout

</a>

&nbsp;&nbsp;

<a class="btn home" href="/">
Continue Shopping

</a>

</div>

</body>

</html>